@{
    ViewData["Title"] = "Join Room";
}

<div class="form-container">
    <h2>🚪 Join a Room</h2>
    <p>Enter the room code shared by your friend.</p>

    @if (ViewBag.Error != null)
    {
        <div class="error-message">@ViewBag.Error</div>
    }

    <form method="post" action="/Lobby/Join">
        <div class="form-group">
            <label>Your Nickname</label>
            <input type="text" name="nickname" maxlength="50"
                   placeholder="Enter your nickname" required />
        </div>

        <div class="form-group">
            <label>Room Code</label>
            <input type="text" name="roomCode" maxlength="6"
                   placeholder="e.g. AB12XY"
                   style="text-transform:uppercase" required />
        </div>

        <button type="submit" class="btn-secondary">Join Room</button>
        <a href="/" class="btn-back">← Back</a>
    </form>
</div>

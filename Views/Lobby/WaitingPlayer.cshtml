@model ScriblleDemo.Models.GameSession

@{
    ViewData["Title"] = "Waiting Room";
    var playerId = ViewContext.HttpContext.Session.GetInt32("PlayerId");
}

<div class="waiting-container">

    <div class="waiting-header player-header">
        <h2>⏳ Waiting Room</h2>
        <span class="role-badge player-role">🎮 You are a Player</span>
    </div>

    <div class="room-code-box">
        <p>Room Code:</p>
        <span class="room-code">@Model.RoomCode</span>
    </div>

    <div class="players-list">
        <h3>Players (<span id="playerCount">@Model.Players.Count</span> / @Model.MaxPlayers)</h3>
        <ul id="playerList">
            @foreach (var player in Model.Players)
            {
                <li>
                    @if (player.Id == playerId)
                    {
                        <strong>@player.Nickname (You)</strong>
                    }
                    else
                    {
                        @player.Nickname
                    }
                    @if (player.IsHost)
                    {
                        <span class="host-badge">👑 Host</span>
                    }
                </li>
            }
        </ul>
    </div>

    <div class="player-waiting-box">
        <div class="spinner"></div>
        <p class="waiting-text">Waiting for the host to start the game...</p>
        <p class="waiting-subtext" id="playerCountText">
            @Model.Players.Count player(s) in room
        </p>
    </div>

    <form method="post" action="/Lobby/LeaveRoom">
        <input type="hidden" name="sessionId" value="@Model.Id" />
        <button type="submit" class="btn-leave">🚪 Leave Room</button>
    </form>

</div>

<script src="~/lib/signalr/dist/browser/signalr.min.js"></script>
<script>
    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/gameHub")
        .build();

    const roomCode = "@Model.RoomCode";
    const myNickname = "@ViewContext.HttpContext.Session.GetString("Nickname")";
    const myPlayerId = @(playerId ?? 0);

    // ── Server sends updated player list ──
    connection.on("UpdatePlayerList", function (players) {
        const list = document.getElementById("playerList");
        const countEl = document.getElementById("playerCount");
        const countText = document.getElementById("playerCountText");

        list.innerHTML = "";
        players.forEach(function (player) {
            const li = document.createElement("li");
            const isMe = player.id === myPlayerId;
            li.innerHTML = isMe
                ? `<strong>${player.nickname} (You)</strong>${player.isHost ? ' <span class="host-badge">👑 Host</span>' : ''}`
                : `${player.nickname}${player.isHost ? ' <span class="host-badge">👑 Host</span>' : ''}`;
            list.appendChild(li);
        });

        countEl.textContent = players.length;
        countText.textContent = players.length + " player(s) in room";
    });

    // ── Server says game has started — redirect immediately ──
    connection.on("GameStarted", function (roomCode) {
        window.location.href = "/Game/Index?roomCode=" + roomCode;
    });

    // ── Connect and join the room group ──
    connection.start()
        .then(function () {
            return connection.invoke("JoinRoom", roomCode, myNickname);
        })
        .catch(function (err) {
            console.error("SignalR error: " + err.toString());
        });
</script>
@model ScriblleDemo.Models.GameSession

@{
    ViewData["Title"] = "Waiting Room - Host";
    var playerId = ViewContext.HttpContext.Session.GetInt32("PlayerId");
}

<div class="waiting-container">

    <div class="waiting-header host-header">
        <h2>⏳ Waiting Room</h2>
        <span class="role-badge host-role">👑 You are the Host</span>
    </div>

    <div class="room-code-box">
        <p>Share this code with friends:</p>
        <span class="room-code">@Model.RoomCode</span>
        <p class="room-hint">Players can join at the home page → Join Room</p>
    </div>

    <div class="players-list">
        <h3>Players (<span id="playerCount">@Model.Players.Count</span> / @Model.MaxPlayers)</h3>
        <ul id="playerList">
            @foreach (var player in Model.Players)
            {
                <li>
                    @if (player.Id == playerId)
                    {
                        <strong>@player.Nickname (You)</strong>
                    }
                    else
                    {
                        @player.Nickname
                    }
                    @if (player.IsHost)
                    {
                        <span class="host-badge">👑 Host</span>
                    }
                </li>
            }
        </ul>
    </div>

    <div class="host-controls">
        <h3>Game Settings</h3>
        <form method="post" action="/Lobby/StartGame" id="startForm">
            <input type="hidden" name="sessionId" value="@Model.Id" />

            <div class="form-group">
                <label>Number of Rounds</label>
                <select name="totalRounds">
                    <option value="3">3 Rounds</option>
                    <option value="5">5 Rounds</option>
                    <option value="8">8 Rounds</option>
                </select>
            </div>

            <button type="button" id="startBtn" class="btn-start"
                    @(Model.Players.Count < 2 ? "disabled" : "")
                    onclick="hostStartGame()">
                🚀 Start Game
            </button>

            <p id="playerHint" class="hint"
               style="@(Model.Players.Count < 2 ? "" : "display:none")">
                ⚠️ Need at least 2 players to start.
            </p>
        </form>

        <form method="post" action="/Lobby/CancelRoom" style="margin-top:12px">
            <input type="hidden" name="sessionId" value="@Model.Id" />
            <button type="submit" class="btn-cancel">❌ Cancel Room</button>
        </form>
    </div>
</div>

<!-- SignalR client library (built into .NET 8, served from wwwroot) -->
<script src="~/lib/signalr/dist/browser/signalr.min.js"></script>
<script>
    // Connect to the Hub we created
    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/gameHub")
        .build();

    const roomCode = "@Model.RoomCode";
    const myNickname = "@ViewContext.HttpContext.Session.GetString("Nickname")";
    const maxPlayers = @Model.MaxPlayers;

    // ── What to do when server sends "UpdatePlayerList" ──
    connection.on("UpdatePlayerList", function (players) {
        const list = document.getElementById("playerList");
        const countEl = document.getElementById("playerCount");
        const startBtn = document.getElementById("startBtn");
        const hint = document.getElementById("playerHint");

        // Rebuild the player list HTML
        list.innerHTML = "";
        players.forEach(function (player) {
            const li = document.createElement("li");
            const isMe = player.nickname === myNickname && player.isHost;
            li.innerHTML = isMe
                ? `<strong>${player.nickname} (You)</strong> <span class="host-badge">👑 Host</span>`
                : `${player.nickname}${player.isHost ? ' <span class="host-badge">👑 Host</span>' : ''}`;
            list.appendChild(li);
        });

        // Update count and enable/disable start button
        countEl.textContent = players.length;
        if (players.length >= 2) {
            startBtn.disabled = false;
            hint.style.display = "none";
        } else {
            startBtn.disabled = true;
            hint.style.display = "block";
        }
    });

    // ── What to do when server says game started ──
    connection.on("GameStarted", function (roomCode) {
        window.location.href = "/Game/Index?roomCode=" + roomCode;
    });

    // ── Start the connection then join the room group ──
    connection.start()
        .then(function () {
            return connection.invoke("JoinRoom", roomCode, myNickname);
        })
        .catch(function (err) {
            console.error("SignalR connection error: " + err.toString());
        });

    // ── Host clicks Start Game ──
    function hostStartGame() {
        // Tell all players via SignalR that game is starting
        connection.invoke("StartGame", roomCode)
            .then(function () {
                // Then submit the form to update DB
                document.getElementById("startForm").submit();
            });
    }
</script>
@model ScriblleDemo.Models.GameSession

@{
    ViewData["Title"] = "Game Over";
    var ranked = (List<ScriblleDemo.Models.Player>)ViewBag.RankedPlayers;
}

<div class="scoreboard-container">
    <h1>🏆 Game Over!</h1>
    <p class="room-code-small">Room: @ViewBag.RoomCode</p>

    <div class="final-scores">
        @for (int i = 0; i < ranked.Count; i++)
        {
            <div class="score-row rank-@(i + 1)">
                <span class="rank-medal">
                    @(i == 0 ? "🥇" : i == 1 ? "🥈" : i == 2 ? "🥉" : $"#{i + 1}")
                </span>
                <span class="score-name">@ranked[i].Nickname</span>
                <span class="score-pts">@ranked[i].Score pts</span>
            </div>
        }
    </div>

    <a href="/" class="btn-primary" style="display:inline-block; margin-top:30px">
        🏠 Back to Home
    </a>
</div>